# =============================================================================
# Healthcare MCP Server — Environment Variables
# =============================================================================
# Uses the SAME keys as the Java Spring Boot backend so both services can
# share a single .env file placed in the demo/ directory.
# =============================================================================

# ── PostgreSQL (JDBC URL — same format as the Java app) ─────────────────────
DB_URL=jdbc:postgresql://localhost:5432/health_chatbot
DB_USER=postgres
DB_PASSWORD=PASSWORD

# ── Connection Pool (optional) ───────────────────────────────────────────────
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=10

# ── Embedding Model ─────────────────────────────────────────────────────────────────
# MUST stay as all-MiniLM-L6-v2 — this is what the Java app uses to build
# the stored embeddings. Changing it would make existing vectors incompatible.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Search (optional) ────────────────────────────────────────────────────────────────
# Number of top chunks returned (mirrors Java TOP_K = 3, bumped to 5 for MCP)
SIMILARITY_TOP_K=5
# Minimum cosine similarity to include a result (mirrors Java threshold = 0.30)
SIMILARITY_THRESHOLD=0.30
